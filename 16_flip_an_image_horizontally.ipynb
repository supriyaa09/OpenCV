   "source": [
    "# Program to flip an image horizontally\n",
    "\n",
    "import cv2\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "img=cv2.imread(\"flower.jpg\")\n",
    "img=cv2.cvtColor(img,cv2.COLOR_BGR2RGB)\n",
    "\n",
    "flip=cv2.flip(img,1)\n",
    "\n",
    "plt.imshow(flip)\n",
    "plt.title(\"Flipped Image\")\n",
    "plt.show()\n",
    "\n"
   ]
  }
 ],
