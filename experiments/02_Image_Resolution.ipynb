   "source": [
    "# Program to convert RGB image into YUV color space\n",
    "import cv2\n",
    "import matplotlib.pyplot as plt\n",
    "img=cv2.imread(\"flower.jpg\")\n",
    "yuv=cv2.cvtColor(img,cv2.COLOR_BGR2YUV)\n",
    "plt.imshow(yuv)\n",
    "plt.show()"
   ]
