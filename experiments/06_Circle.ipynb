   "source": [
    "# Program to draw a circle on an image\n",
    "import cv2\n",
    "import matplotlib.pyplot as plt\n",
    "img=cv2.imread(\"flower.jpg\")\n",
    "img=cv2.cvtColor(img,cv2.COLOR_BGR2RGB)\n",
    "cv2.circle(img,(110,110),60,(255,0,0),3)\n",
    "plt.imshow(img)\n",
    "plt.show()"
   ]
